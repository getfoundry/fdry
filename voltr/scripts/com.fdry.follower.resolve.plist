<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.fdry.follower.resolve</string>

    <key>ProgramArguments</key>
    <array>
        <string>~/Projects/fdry/voltr/scripts/run-follower</string>
        <string>follower:resolve</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <!-- Run every hour. -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <key>StandardOutPath</key>
    <string>~/Library/Logs/fdry.resolve.log</string>

    <key>StandardErrorPath</key>
    <string>~/Library/Logs/fdry.resolve.err</string>

    <key>WorkingDirectory</key>
    <string>~/Projects/fdry/voltr</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>
</dict>
</plist>
