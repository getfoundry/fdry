#!/bin/bash
# Source ~/.fdry/env into the process environment, then exec $@.
# Never echoes, greps, or prints the file contents.
ENV_FILE="$HOME/.fdry/env"
if [ ! -f "$ENV_FILE" ]; then
  echo "error: $ENV_FILE not found" >&2
  exit 1
fi
if [ ! -r "$ENV_FILE" ]; then
  echo "error: $ENV_FILE not readable (check chmod)" >&2
  exit 1
fi
set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a
# Optional: assert we're on mainnet if requested
if [ "$1" = "--require-mainnet" ]; then
  shift
  if [ "$SOLANA_CLUSTER" != "mainnet-beta" ]; then
    echo "error: refusing to run — SOLANA_CLUSTER != mainnet-beta" >&2
    exit 1
  fi
fi
exec "$@"
