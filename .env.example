# ============================================================================
# fdry — environment variables
# ----------------------------------------------------------------------------
# Copy to .env (gitignored) and fill in real values.
# NEVER commit .env with real secrets. Rotate any key that leaks.
# ============================================================================

# ----------------------------------------------------------------------------
# Solana RPC
# ----------------------------------------------------------------------------
# Primary RPC endpoint. Prefer a paid provider (Helius / Triton / QuickNode)
# for reliability — public endpoints rate-limit and drop under load.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ----------------------------------------------------------------------------
# Wallets — secrets. NEVER COMMIT. NEVER LOG. NEVER PASTE IN CHAT.
# ----------------------------------------------------------------------------
# Creator keypair (base58-encoded 64-byte secret key).
# Owns the Symmetry vault. Used only for createVault / config changes.
# Keep this key OFFLINE when possible; rotate if it ever touches a networked host.
CREATOR_KEY=REPLACE_WITH_BASE58_CREATOR_SECRET_KEY

# Hot wallet keypair (base58-encoded 64-byte secret key).
# Pays tx fees and executes daily rebalances. Fund with a small SOL buffer only.
HOT_WALLET_KEY=REPLACE_WITH_BASE58_HOT_WALLET_SECRET_KEY

# ----------------------------------------------------------------------------
# Symmetry vault
# ----------------------------------------------------------------------------
# Vault public key. Empty on first deploy — fill in after \`createVault\` runs.
VAULT_PUBKEY=

# Symmetry program ID (mainnet). Do not change unless Symmetry upgrades.
SYMMETRY_PROGRAM_ID=BASKT7aKd8n7ibpUbwLP3Wiyxyi3yoiXsxBk4Hpumate

# ----------------------------------------------------------------------------
# Telegram alerts (optional)
# ----------------------------------------------------------------------------
# Bot token from @BotFather. Leave empty to disable Telegram alerts.
TELEGRAM_BOT_TOKEN=
# Target chat ID (user or group). Negative for groups.
TELEGRAM_CHAT_ID=

# ----------------------------------------------------------------------------
# Dead-man switch (optional)
# ----------------------------------------------------------------------------
# healthchecks.io UUID. Bot pings this after every successful run.
# If the ping stops, healthchecks.io alerts you. Leave empty to disable.
HEALTHCHECK_UUID=

# ----------------------------------------------------------------------------
# Paths
# ----------------------------------------------------------------------------
# Where the daily signal JSON lives (produced upstream by the signal job).
SIGNAL_FILE_PATH=~/Projects/fdry/runs/daily_signal/latest.json

# Where the ledger (snapshots, rebalance history) is persisted.
LEDGER_DIR=~/Projects/fdry/ledger
# ----------------------------------------------------------------------------
# Additional variables referenced by bot/scripts (audit 2026-04-20)
# ----------------------------------------------------------------------------
# Legacy/alternate RPC_URL name used by bot/src/main.ts, scripts/seed.ts,
# scripts/createVault.ts. Keep in sync with SOLANA_RPC_URL above.
RPC_URL=https://api.mainnet-beta.solana.com

# Hot wallet public key — required by createVault (validates against HOT_WALLET_KEY).
HOT_WALLET=REPLACE_WITH_BASE58_HOT_WALLET_PUBKEY

# Creator wallet public key (createVault cross-checks CREATOR_KEY against this).
CREATOR_WALLET=REPLACE_WITH_BASE58_CREATOR_PUBKEY

# Set to "1" to force dry-run mode without --dry-run flag. Leave empty for live.
DRY_RUN=

# Solana cluster label used in startup alert + Solscan explorer links.
# One of: mainnet-beta | devnet | testnet.
SOLANA_CLUSTER=mainnet-beta

# Pyth Hermes API base URL (seed.ts pulls oracle prices).
PYTH_HERMES_URL=https://hermes.pyth.network

# Keeper-convergence polling (seed.ts). Defaults: 600s total, 10s interval.
KEEPER_POLL_TIMEOUT_SEC=600
KEEPER_POLL_INTERVAL_SEC=10

# Symmetry SDK network selector. One of: mainnet | devnet.
SYMMETRY_NETWORK=mainnet
