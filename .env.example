# ============================================================================
# fdry — environment variables
# ----------------------------------------------------------------------------
# Copy to .env (gitignored) and fill in real values.
# NEVER commit .env with real secrets. Rotate any key that leaks.
# ============================================================================

# ----------------------------------------------------------------------------
# Solana RPC
# ----------------------------------------------------------------------------
# Primary RPC endpoint. Prefer a paid provider (Helius / Triton / QuickNode)
# for reliability — public endpoints rate-limit and drop under load.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana cluster label used in startup alerts and Solscan explorer links.
# One of: mainnet-beta | devnet | testnet.
SOLANA_CLUSTER=mainnet-beta

# Legacy alias also read by some scripts. Keep in sync with SOLANA_RPC_URL.
RPC_URL=https://api.mainnet-beta.solana.com

# ----------------------------------------------------------------------------
# Wallets — secrets. NEVER COMMIT. NEVER LOG. NEVER PASTE IN CHAT.
# ----------------------------------------------------------------------------
# Creator keypair (base58-encoded 64-byte secret key).
# Owns the Voltr/Ranger vault. Used only for vault creation / admin changes.
# Keep this key OFFLINE when possible; rotate if it ever touches a networked host.
CREATOR_KEY=REPLACE_WITH_BASE58_CREATOR_SECRET_KEY
CREATOR_WALLET=REPLACE_WITH_BASE58_CREATOR_PUBKEY

# Hot wallet / manager keypair (base58-encoded 64-byte secret key).
# Pays tx fees and signs follower trades. Fund with a small SOL buffer only.
HOT_WALLET_KEY=REPLACE_WITH_BASE58_HOT_WALLET_SECRET_KEY
HOT_WALLET=REPLACE_WITH_BASE58_HOT_WALLET_PUBKEY

# Jup-follower manager keypair (referenced as path, not raw secret).
# Generated via `solana-keygen new --outfile ~/.fdry/manager.json`.
# Used by voltr/src/follower/submitOrder.ts in test/live modes.
MANAGER_KEYPAIR_PATH=/Users/lekt9/.fdry/manager.json
FDRY_MANAGER_PUBKEY=

# ----------------------------------------------------------------------------
# Voltr / Ranger vault
# ----------------------------------------------------------------------------
# Voltr vault PDA — fill in after createVault runs.
FDRY_VAULT_PUBKEY=

# ----------------------------------------------------------------------------
# Jup Prediction (BETA)
# ----------------------------------------------------------------------------
# API key from Jup. Rotate periodically; treat as a secret.
JUP_PREDICTION_API_KEY=

# Follower mode: paper (default, no signing) | test ($5/trade, $50 total cap) | live.
FDRY_FOLLOWER_MODE=paper

# ----------------------------------------------------------------------------
# Signal pipeline
# ----------------------------------------------------------------------------
# Where the trigger ndjson is written by the upstream imabettingman detector.
SIGNAL_FILE_PATH=/Users/lekt9/.fdry/triggers.ndjson

# Where the ledger (paper trades, resolved trades, history) is persisted.
LEDGER_DIR=/Users/lekt9/Projects/fdry/ledger

# ----------------------------------------------------------------------------
# Pyth (used for oracle price reads)
# ----------------------------------------------------------------------------
PYTH_HERMES_URL=https://hermes.pyth.network

# ----------------------------------------------------------------------------
# Telegram alerts (optional)
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----------------------------------------------------------------------------
# Dead-man switch (optional)
# ----------------------------------------------------------------------------
# healthchecks.io UUID. Bot pings this after every successful run.
HEALTHCHECK_UUID=

# ----------------------------------------------------------------------------
# Misc runtime
# ----------------------------------------------------------------------------
# Set to "1" to force dry-run mode without --dry-run flag. Leave empty for live.
DRY_RUN=

# Keeper-convergence polling (where applicable). Defaults: 600s total, 10s interval.
KEEPER_POLL_TIMEOUT_SEC=600
KEEPER_POLL_INTERVAL_SEC=10
